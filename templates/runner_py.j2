#!/usr/bin/env python3
"""
Generated by doe.py on {{ timestamp }}
Operation: {{ operation }}
Total runs: {{ total_runs }}
"""

import subprocess
import os
import sys

RUNS = [
{% for run in runs %}    {
        "run_id": {{ run.run_id }},
        "block_id": {{ run.block_id }},
        "factors": {{ run.factor_values | tojson }},
    },
{% endfor %}]

TEST_SCRIPT = "{{ test_script }}"
OUT_DIRECTORY = "{{ out_directory }}"
STATIC_SETTINGS = {{ static_settings | tojson }}

os.makedirs(OUT_DIRECTORY, exist_ok=True)

print(f"Starting {{ total_runs }} experiment runs...")

for run in RUNS:
    run_id = run["run_id"]
    block_id = run["block_id"]
    factors = run["factors"]

    print(f"\n=== Run {run_id} / {{ total_runs }} (Block {block_id}) ===")
    for name, value in factors.items():
        print(f"  {name} = {value}")

    cmd = [TEST_SCRIPT]
    for name, value in factors.items():
        cmd += [f"--{name}", value]
    cmd += STATIC_SETTINGS
    cmd += ["--out", f"{OUT_DIRECTORY}/run_{run_id}.json"]

    result = subprocess.run(cmd, check=True)

print(f"\nAll runs complete. Results in: {OUT_DIRECTORY}")
