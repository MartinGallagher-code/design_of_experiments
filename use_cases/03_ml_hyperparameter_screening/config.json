{
    "metadata": {
        "name": "ML Hyperparameter Screening",
        "description": "Fractional factorial to screen 5 hyperparameters with minimal runs"
    },
    "factors": [
        {"name": "learning_rate", "levels": ["0.001", "0.1"],    "type": "continuous", "unit": "",     "description": "SGD learning rate"},
        {"name": "batch_size",    "levels": ["32", "256"],        "type": "continuous", "unit": "",     "description": "Training batch size"},
        {"name": "dropout",       "levels": ["0.1", "0.5"],       "type": "continuous", "unit": "",     "description": "Dropout probability"},
        {"name": "hidden_layers", "levels": ["2", "6"],           "type": "continuous", "unit": "",     "description": "Number of hidden layers"},
        {"name": "optimizer",     "levels": ["sgd", "adam"],      "type": "categorical",               "description": "Optimization algorithm"}
    ],
    "fixed_factors": {
        "epochs": "50",
        "dataset": "cifar10"
    },
    "responses": [
        {"name": "accuracy",      "optimize": "maximize", "unit": "%",  "description": "Test set accuracy"},
        {"name": "training_time", "optimize": "minimize", "unit": "sec", "description": "Wall-clock training time"}
    ],
    "runner": {
        "arg_style": "positional"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/03_ml_hyperparameter_screening/sim.sh",
        "operation": "fractional_factorial",
        "processed_directory": "use_cases/03_ml_hyperparameter_screening/results/analysis",
        "out_directory": "use_cases/03_ml_hyperparameter_screening/results"
    }
}
