{
    "metadata": {
        "name": "BLE Mesh Topology",
        "description": "Box-Behnken design to tune relay count, TTL hops, and publish interval for message delivery and latency"
    },
    "factors": [
        {
            "name": "relay_count",
            "levels": [
                "2",
                "10"
            ],
            "type": "continuous",
            "unit": "nodes",
            "description": "Number of relay nodes in mesh"
        },
        {
            "name": "ttl_hops",
            "levels": [
                "2",
                "8"
            ],
            "type": "continuous",
            "unit": "hops",
            "description": "Message TTL in hops"
        },
        {
            "name": "publish_interval_ms",
            "levels": [
                "100",
                "2000"
            ],
            "type": "continuous",
            "unit": "ms",
            "description": "Message publish interval"
        }
    ],
    "fixed_factors": {
        "ble_version": "5.0",
        "mesh_profile": "sig_mesh"
    },
    "responses": [
        {
            "name": "message_delivery_pct",
            "optimize": "maximize",
            "unit": "%",
            "description": "Message delivery success rate",
            "weight": 1.5
        },
        {
            "name": "network_latency_ms",
            "optimize": "minimize",
            "unit": "ms",
            "description": "End-to-end network latency",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/68_ble_mesh_topology/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/68_ble_mesh_topology/results/analysis",
        "out_directory": "use_cases/68_ble_mesh_topology/results"
    }
}
