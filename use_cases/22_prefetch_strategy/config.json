{
    "metadata": {
        "name": "Hardware & Software Prefetch Tuning",
        "description": "Plackett-Burman screening design to identify critical prefetch parameters for memory-bound CFD workloads"
    },
    "factors": [
        {
            "name": "hw_prefetcher",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Hardware L2 adjacent-line prefetcher"
        },
        {
            "name": "sw_prefetch_dist",
            "levels": [
                "64",
                "512"
            ],
            "type": "continuous",
            "unit": "bytes",
            "description": "Software prefetch distance ahead of access"
        },
        {
            "name": "l2_stream_detect",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "L2 hardware stream detector"
        },
        {
            "name": "dcache_policy",
            "levels": [
                "write_back",
                "write_through"
            ],
            "type": "categorical",
            "unit": "",
            "description": "L1 data cache write policy"
        },
        {
            "name": "prefetch_threads",
            "levels": [
                "0",
                "2"
            ],
            "type": "continuous",
            "unit": "",
            "description": "Dedicated software prefetch helper threads"
        },
        {
            "name": "tlb_prefetch",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "TLB entry prefetching"
        }
    ],
    "fixed_factors": {
        "processor": "Xeon_8490H",
        "workload": "CFD_structured_grid",
        "grid_points": "256M",
        "iterations": "100"
    },
    "responses": [
        {
            "name": "solver_time_sec",
            "optimize": "minimize",
            "unit": "seconds",
            "description": "Total solver wall-clock time for 100 iterations",
            "weight": 1.5
        },
        {
            "name": "cache_miss_rate",
            "optimize": "minimize",
            "unit": "%",
            "description": "LLC miss rate",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 2,
        "test_script": "use_cases/22_prefetch_strategy/sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "use_cases/22_prefetch_strategy/results/analysis",
        "out_directory": "use_cases/22_prefetch_strategy/results"
    }
}
