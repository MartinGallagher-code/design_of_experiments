        },
        {
            "name": "density_score",
            "optimize": "maximize",
            "unit": "pts",
            "description": "Felt density and firmness (1-10)",
            "weight": 1.5
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/184_wool_felting/sim.sh",
        "operation": "fractional_factorial",
        "processed_directory": "use_cases/184_wool_felting/results/analysis",
        "out_directory": "use_cases/184_wool_felting/results"
    }
