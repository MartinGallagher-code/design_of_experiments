{
    "metadata": {
        "name": "Audio Amplifier Biasing",
        "description": "Box-Behnken design to maximize THD+N and headroom by tuning bias current, supply voltage, and feedback ratio"
    },
    "factors": [
        {
            "name": "bias_ma",
            "levels": [
                "10",
                "100"
            ],
            "type": "continuous",
            "unit": "mA",
            "description": "Output stage quiescent bias current"
        },
        {
            "name": "supply_v",
            "levels": [
                "15",
                "35"
            ],
            "type": "continuous",
            "unit": "V",
            "description": "Power supply voltage (per rail)"
        },
        {
            "name": "feedback_db",
            "levels": [
                "10",
                "30"
            ],
            "type": "continuous",
            "unit": "dB",
            "description": "Negative feedback amount"
        }
    ],
    "fixed_factors": {
        "topology": "class_AB",
        "load": "8ohm"
    },
    "responses": [
        {
            "name": "thd_pct",
            "optimize": "minimize",
            "unit": "%",
            "description": "Total harmonic distortion + noise",
            "weight": 1.0
        },
        {
            "name": "headroom_db",
            "optimize": "maximize",
            "unit": "dB",
            "description": "Dynamic headroom above rated power",
            "weight": 1.5
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/275_audio_amplifier/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/275_audio_amplifier/results/analysis",
        "out_directory": "use_cases/275_audio_amplifier/results"
    }
}
