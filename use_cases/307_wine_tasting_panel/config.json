{
    "metadata": {
        "name": "Wine Tasting Panel",
        "description": "Box-Behnken design with 3 tasting panel blocks to optimize wine blending parameters for aroma and balance"
    },
    "factors": [
        {
            "name": "oak_aging",
            "levels": ["3", "18"],
            "type": "continuous",
            "unit": "months",
            "description": "Oak barrel aging duration"
        },
        {
            "name": "sugar_residual",
            "levels": ["1", "8"],
            "type": "continuous",
            "unit": "g/L",
            "description": "Residual sugar level"
        },
        {
            "name": "sulfite_level",
            "levels": ["20", "60"],
            "type": "continuous",
            "unit": "mg/L",
            "description": "Free sulfite concentration"
        }
    ],
    "fixed_factors": {
        "grape_variety": "cabernet_sauvignon",
        "vintage": "2024"
    },
    "responses": [
        {
            "name": "aroma_score",
            "optimize": "maximize",
            "unit": "pts",
            "description": "Aroma complexity score from tasting panel (1-10)",
            "weight": 1.5
        },
        {
            "name": "balance_score",
            "optimize": "maximize",
            "unit": "pts",
            "description": "Overall balance score from tasting panel (1-10)",
            "weight": 1.5
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 3,
        "test_script": "use_cases/307_wine_tasting_panel/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/307_wine_tasting_panel/results/analysis",
        "out_directory": "use_cases/307_wine_tasting_panel/results"
    }
}
