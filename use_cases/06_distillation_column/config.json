{
    "metadata": {
        "name": "Distillation Column Optimization",
        "description": "Central Composite Design to model and optimize separation efficiency"
    },
    "factors": [
        {"name": "reflux_ratio",    "levels": ["1.5", "4.5"], "type": "continuous", "unit": "",    "description": "Reflux ratio (L/D)"},
        {"name": "feed_rate",       "levels": ["50", "150"],   "type": "continuous", "unit": "L/h", "description": "Feed stream flow rate"},
        {"name": "column_pressure", "levels": ["1.0", "3.0"],  "type": "continuous", "unit": "atm", "description": "Column operating pressure"}
    ],
    "fixed_factors": {
        "feed_temp": "80",
        "n_trays": "20"
    },
    "responses": [
        {"name": "separation_efficiency", "optimize": "maximize", "unit": "%",   "description": "Top product purity"},
        {"name": "energy_cost",           "optimize": "minimize", "unit": "USD/h", "description": "Reboiler energy cost"}
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/06_distillation_column/sim.sh",
        "operation": "central_composite",
        "processed_directory": "use_cases/06_distillation_column/results/analysis",
        "out_directory": "use_cases/06_distillation_column/results"
    }
}
