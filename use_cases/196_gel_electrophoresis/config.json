        },
        {
            "name": "load_ul",
            "levels": [
                "5",
                "25"
            ],
            "type": "continuous",
            "unit": "uL",
            "description": "Sample loading volume"
        }
    ],
    "fixed_factors": {
        "buffer": "TAE_1x",
        "stain": "ethidium_bromide"
