    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/196_gel_electrophoresis/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/196_gel_electrophoresis/results/analysis",
