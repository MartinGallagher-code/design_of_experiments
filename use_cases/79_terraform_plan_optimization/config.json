{
    "metadata": {
        "name": "Terraform Plan Optimization",
        "description": "Plackett-Burman screening of 6 Terraform parameters for plan time and state drift detection"
    },
    "factors": [
        {
            "name": "parallelism",
            "levels": [
                "1",
                "20"
            ],
            "type": "continuous",
            "unit": "threads",
            "description": "Terraform operation parallelism"
        },
        {
            "name": "refresh_enabled",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "State refresh before plan"
        },
        {
            "name": "state_lock_timeout",
            "levels": [
                "5",
                "120"
            ],
            "type": "continuous",
            "unit": "sec",
            "description": "State lock acquisition timeout"
        },
        {
            "name": "provider_cache",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Provider plugin caching"
        },
        {
            "name": "plan_out_format",
            "levels": [
                "text",
                "json"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Plan output format"
        },
        {
            "name": "detailed_exitcode",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Detailed exit code enabled"
        }
    ],
    "fixed_factors": {
        "backend": "s3",
        "provider": "aws"
    },
    "responses": [
        {
            "name": "plan_time_sec",
            "optimize": "minimize",
            "unit": "sec",
            "description": "Terraform plan execution time"
        },
        {
            "name": "state_drift_detected",
            "optimize": "maximize",
            "unit": "count",
            "description": "Number of state drifts detected"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/79_terraform_plan_optimization/sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "use_cases/79_terraform_plan_optimization/results/analysis",
        "out_directory": "use_cases/79_terraform_plan_optimization/results"
    }
}