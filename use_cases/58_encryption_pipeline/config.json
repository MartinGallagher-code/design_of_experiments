{
    "metadata": {
        "name": "Encryption Pipeline Optimization",
        "description": "Full factorial of cipher suite, key size, compression, and hardware acceleration for throughput and CPU overhead"
    },
    "factors": [
        {
            "name": "cipher_suite",
            "levels": [
                "aes128",
                "aes256"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Cipher suite selection"
        },
        {
            "name": "key_size",
            "levels": [
                "128",
                "256"
            ],
            "type": "continuous",
            "unit": "bits",
            "description": "Encryption key size"
        },
        {
            "name": "compression_before_encrypt",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Compress before encryption"
        },
        {
            "name": "hardware_acceleration",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "AES-NI hardware acceleration"
        }
    ],
    "fixed_factors": {
        "protocol": "tls1.3",
        "mode": "gcm"
    },
    "responses": [
        {
            "name": "throughput_mbps",
            "optimize": "maximize",
            "unit": "Mbps",
            "description": "Encryption throughput"
        },
        {
            "name": "cpu_overhead_pct",
            "optimize": "minimize",
            "unit": "%",
            "description": "CPU overhead from encryption"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/58_encryption_pipeline/sim.sh",
        "operation": "full_factorial",
        "processed_directory": "use_cases/58_encryption_pipeline/results/analysis",
        "out_directory": "use_cases/58_encryption_pipeline/results"
    }
}