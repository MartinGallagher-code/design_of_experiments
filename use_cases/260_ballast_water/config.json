        {
            "name": "treatment_min",
            "optimize": "minimize",
            "unit": "min/100m3",
            "description": "Treatment time per 100m3"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/260_ballast_water/sim.sh",
        "operation": "central_composite",
        "processed_directory": "use_cases/260_ballast_water/results/analysis",
        "out_directory": "use_cases/260_ballast_water/results"
    }
