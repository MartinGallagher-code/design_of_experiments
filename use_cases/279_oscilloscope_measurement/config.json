{
    "metadata": {
        "name": "Oscilloscope Measurement Setup",
        "description": "Box-Behnken design to maximize measurement accuracy and minimize noise floor by tuning vertical scale, bandwidth limit, and sample rate"
    },
    "factors": [
        {
            "name": "v_div_mv",
            "levels": [
                "10",
                "500"
            ],
            "type": "continuous",
            "unit": "mV/div",
            "description": "Vertical scale setting"
        },
        {
            "name": "bw_mhz",
            "levels": [
                "20",
                "200"
            ],
            "type": "continuous",
            "unit": "MHz",
            "description": "Bandwidth limit setting"
        },
        {
            "name": "sample_msa",
            "levels": [
                "100",
                "2000"
            ],
            "type": "continuous",
            "unit": "MSa/s",
            "description": "Sample rate"
        }
    ],
    "fixed_factors": {
        "probe": "10x",
        "coupling": "DC"
    },
    "responses": [
        {
            "name": "accuracy_pct",
            "optimize": "maximize",
            "unit": "%",
            "description": "Measurement accuracy vs reference"
        },
        {
            "name": "noise_floor_mv",
            "optimize": "minimize",
            "unit": "mV_rms",
            "description": "Noise floor in mV RMS"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/279_oscilloscope_measurement/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/279_oscilloscope_measurement/results/analysis",
        "out_directory": "use_cases/279_oscilloscope_measurement/results"
    }
}