        {
            "name": "strength_28d_mpa",
            "optimize": "maximize",
            "unit": "MPa",
            "description": "28-day compressive strength"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/236_concrete_aggregate/sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "use_cases/236_concrete_aggregate/results/analysis",
        "out_directory": "use_cases/236_concrete_aggregate/results"
    }
}