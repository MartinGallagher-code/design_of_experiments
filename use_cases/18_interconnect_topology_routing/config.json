{
    "metadata": {
        "name": "Interconnect Topology & Adaptive Routing",
        "description": "Plackett-Burman screening design to identify dominant factors in dragonfly network routing performance"
    },
    "factors": [
        {
            "name": "routing_mode",
            "levels": ["minimal", "adaptive"],
            "type": "categorical",
            "unit": "",
            "description": "Routing algorithm — minimal (shortest path) vs adaptive (congestion-aware)"
        },
        {
            "name": "vc_count",
            "levels": ["2", "8"],
            "type": "continuous",
            "unit": "",
            "description": "Number of virtual channels per physical link"
        },
        {
            "name": "traffic_pattern",
            "levels": ["nearest_neighbor", "alltoall"],
            "type": "categorical",
            "unit": "",
            "description": "Application communication pattern"
        },
        {
            "name": "link_bandwidth",
            "levels": ["100", "200"],
            "type": "continuous",
            "unit": "Gbps",
            "description": "Per-link injection bandwidth"
        },
        {
            "name": "job_placement",
            "levels": ["compact", "scatter"],
            "type": "categorical",
            "unit": "",
            "description": "Job placement strategy across groups"
        }
    ],
    "fixed_factors": {
        "topology": "dragonfly",
        "groups": "16",
        "switches_per_group": "48",
        "nodes": "3072"
    },
    "responses": [
        {
            "name": "msg_latency_us",
            "optimize": "minimize",
            "unit": "us",
            "description": "Average message latency"
        },
        {
            "name": "throughput_GBs",
            "optimize": "maximize",
            "unit": "GB/s",
            "description": "Aggregate bisection throughput"
        }
    ],
    "runner": { "arg_style": "double-dash" },
    "settings": {
        "block_count": 2,
        "test_script": "use_cases/18_interconnect_topology_routing/sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "use_cases/18_interconnect_topology_routing/results/analysis",
        "out_directory": "use_cases/18_interconnect_topology_routing/results"
    }
}
