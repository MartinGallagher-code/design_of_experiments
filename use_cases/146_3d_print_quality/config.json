{
    "metadata": {
        "name": "3D Print Quality Tuning",
        "description": "Central composite design to maximize surface quality and minimize print time by tuning layer height, print speed, nozzle temperature, and infill percentage"
    },
    "factors": [
        {
            "name": "layer_height_mm",
            "levels": [
                "0.1",
                "0.3"
            ],
            "type": "continuous",
            "unit": "mm",
            "description": "Layer height"
        },
        {
            "name": "print_speed",
            "levels": [
                "30",
                "80"
            ],
            "type": "continuous",
            "unit": "mm/s",
            "description": "Print head speed"
        },
        {
            "name": "nozzle_temp_c",
            "levels": [
                "190",
                "220"
            ],
            "type": "continuous",
            "unit": "C",
            "description": "Nozzle temperature for PLA"
        },
        {
            "name": "infill_pct",
            "levels": [
                "10",
                "50"
            ],
            "type": "continuous",
            "unit": "%",
            "description": "Infill percentage"
        }
    ],
    "fixed_factors": {
        "material": "PLA",
        "bed_temp": "60C"
    },
    "responses": [
        {
            "name": "surface_quality",
            "optimize": "maximize",
            "unit": "pts",
            "description": "Surface quality score (1-10)",
            "weight": 1.5
        },
        {
            "name": "print_time_min",
            "optimize": "minimize",
            "unit": "min",
            "description": "Total print time for benchmark part",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/146_3d_print_quality/sim.sh",
        "operation": "central_composite",
        "processed_directory": "use_cases/146_3d_print_quality/results/analysis",
        "out_directory": "use_cases/146_3d_print_quality/results"
    }
}
