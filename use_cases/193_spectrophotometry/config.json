{
    "metadata": {
        "name": "UV-Vis Spectrophotometry",
        "description": "Box-Behnken design to maximize signal-to-noise ratio and minimize baseline drift by tuning slit width, scan speed, and sample path length"
    },
    "factors": [
        {
            "name": "slit_nm",
            "levels": [
                "0.5",
                "5.0"
            ],
            "type": "continuous",
            "unit": "nm",
            "description": "Monochromator slit width"
        },
        {
            "name": "scan_speed",
            "levels": [
                "100",
                "1000"
            ],
            "type": "continuous",
            "unit": "nm/min",
            "description": "Wavelength scan speed"
        },
        {
            "name": "path_cm",
            "levels": [
                "0.1",
                "5.0"
            ],
            "type": "continuous",
            "unit": "cm",
            "description": "Cuvette path length"
        }
    ],
    "fixed_factors": {
        "lamp": "deuterium",
        "wavelength": "260nm"
    },
    "responses": [
        {
            "name": "snr",
            "optimize": "maximize",
            "unit": "ratio",
            "description": "Signal-to-noise ratio",
            "weight": 1.5
        },
        {
            "name": "baseline_drift",
            "optimize": "minimize",
            "unit": "AU/hr",
            "description": "Baseline drift in absorbance units per hour",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/193_spectrophotometry/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/193_spectrophotometry/results/analysis",
        "out_directory": "use_cases/193_spectrophotometry/results"
    }
}
