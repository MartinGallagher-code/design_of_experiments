{
    "metadata": {
        "name": "Chromatography Separation",
        "description": "Box-Behnken design to maximize resolution and minimize run time by tuning flow rate, mobile phase ratio, and column temperature"
    },
    "factors": [
        {
            "name": "flow_ml_min",
            "levels": [
                "0.5",
                "2.0"
            ],
            "type": "continuous",
            "unit": "mL/min",
            "description": "Mobile phase flow rate"
        },
        {
            "name": "organic_pct",
            "levels": [
                "30",
                "80"
            ],
            "type": "continuous",
            "unit": "%",
            "description": "Organic solvent percentage in mobile phase"
        },
        {
            "name": "column_temp_c",
            "levels": [
                "25",
                "55"
            ],
            "type": "continuous",
            "unit": "C",
            "description": "Column oven temperature"
        }
    ],
    "fixed_factors": {
        "column": "C18_150mm",
        "detector": "UV_254nm"
    },
    "responses": [
        {
            "name": "resolution",
            "optimize": "maximize",
            "unit": "Rs",
            "description": "Peak resolution between critical pair",
            "weight": 1.5
        },
        {
            "name": "run_time_min",
            "optimize": "minimize",
            "unit": "min",
            "description": "Total chromatographic run time",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/189_chromatography_separation/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/189_chromatography_separation/results/analysis",
        "out_directory": "use_cases/189_chromatography_separation/results"
    }
}
