{
    "metadata": {
        "name": "Service Mesh Sidecar",
        "description": "Plackett-Burman screening of 6 Envoy sidecar parameters for latency overhead and resource usage"
    },
    "factors": [
        {
            "name": "concurrency",
            "levels": [
                "1",
                "8"
            ],
            "type": "continuous",
            "unit": "threads",
            "description": "Envoy worker threads"
        },
        {
            "name": "circuit_breaker_max",
            "levels": [
                "100",
                "10000"
            ],
            "type": "continuous",
            "unit": "conns",
            "description": "Max circuit breaker connections"
        },
        {
            "name": "access_log",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Access logging enabled"
        },
        {
            "name": "tracing_sample_pct",
            "levels": [
                "1",
                "100"
            ],
            "type": "continuous",
            "unit": "%",
            "description": "Distributed tracing sample rate"
        },
        {
            "name": "compression",
            "levels": [
                "off",
                "on"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Response compression"
        },
        {
            "name": "connection_pool",
            "levels": [
                "100",
                "1000"
            ],
            "type": "continuous",
            "unit": "conns",
            "description": "Upstream connection pool size"
        }
    ],
    "fixed_factors": {
        "mesh": "istio",
        "protocol": "http2"
    },
    "responses": [
        {
            "name": "latency_overhead_ms",
            "optimize": "minimize",
            "unit": "ms",
            "description": "Added proxy latency"
        },
        {
            "name": "sidecar_cpu_pct",
            "optimize": "minimize",
            "unit": "%",
            "description": "Sidecar CPU usage"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/35_service_mesh_sidecar/sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "use_cases/35_service_mesh_sidecar/results/analysis",
        "out_directory": "use_cases/35_service_mesh_sidecar/results"
    }
}