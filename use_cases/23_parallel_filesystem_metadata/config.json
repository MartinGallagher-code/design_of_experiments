{
    "metadata": {
        "name": "Parallel Filesystem Metadata Performance",
        "description": "Fractional factorial 2^(5-1) design to optimize Lustre MDS performance for metadata-intensive HPC workflows"
    },
    "factors": [
        {
            "name": "mdt_count",
            "levels": ["1", "4"],
            "type": "continuous",
            "unit": "",
            "description": "Number of metadata targets (DNE striping)"
        },
        {
            "name": "dir_stripe",
            "levels": ["off", "on"],
            "type": "categorical",
            "unit": "",
            "description": "Directory-level metadata striping (DNE2)"
        },
        {
            "name": "client_cache",
            "levels": ["off", "on"],
            "type": "categorical",
            "unit": "",
            "description": "Client-side metadata caching"
        },
        {
            "name": "commit_on_share",
            "levels": ["0", "1"],
            "type": "categorical",
            "unit": "",
            "description": "Commit-on-sharing for cross-client consistency"
        },
        {
            "name": "mds_threads",
            "levels": ["64", "512"],
            "type": "continuous",
            "unit": "",
            "description": "MDS service thread count"
        }
    ],
    "fixed_factors": {
        "filesystem": "Lustre_2.15",
        "clients": "256",
        "files_per_dir": "100000",
        "file_size": "4KB"
    },
    "responses": [
        {
            "name": "creates_per_sec",
            "optimize": "maximize",
            "unit": "ops/s",
            "description": "File creation rate (mdtest)"
        },
        {
            "name": "stat_per_sec",
            "optimize": "maximize",
            "unit": "ops/s",
            "description": "File stat rate (mdtest)"
        }
    ],
    "runner": { "arg_style": "double-dash" },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/23_parallel_filesystem_metadata/sim.sh",
        "operation": "fractional_factorial",
        "processed_directory": "use_cases/23_parallel_filesystem_metadata/results/analysis",
        "out_directory": "use_cases/23_parallel_filesystem_metadata/results"
    }
}
