{
    "metadata": {
        "name": "Stream Processing Windowing",
        "description": "Box-Behnken design to tune Flink window size, watermark delay, and parallelism for latency and accuracy"
    },
    "factors": [
        {
            "name": "window_size_s",
            "levels": [
                "5",
                "120"
            ],
            "type": "continuous",
            "unit": "s",
            "description": "Tumbling window size"
        },
        {
            "name": "watermark_delay_s",
            "levels": [
                "1",
                "30"
            ],
            "type": "continuous",
            "unit": "s",
            "description": "Allowed event-time lateness"
        },
        {
            "name": "parallelism",
            "levels": [
                "4",
                "32"
            ],
            "type": "continuous",
            "unit": "slots",
            "description": "Job parallelism"
        }
    ],
    "fixed_factors": {
        "checkpoint_interval_ms": "10000",
        "state_backend": "rocksdb"
    },
    "responses": [
        {
            "name": "end_to_end_latency_ms",
            "optimize": "minimize",
            "unit": "ms",
            "description": "End-to-end processing latency"
        },
        {
            "name": "result_accuracy",
            "optimize": "maximize",
            "unit": "%",
            "description": "Result completeness/accuracy"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/39_stream_processing_windowing/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/39_stream_processing_windowing/results/analysis",
        "out_directory": "use_cases/39_stream_processing_windowing/results"
    }
}