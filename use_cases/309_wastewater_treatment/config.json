{
    "metadata": {
        "name": "Wastewater Treatment Optimization",
        "description": "Plackett-Burman screening of 7 factors (5 continuous, 2 ordinal) for BOD removal and sludge volume in wastewater treatment"
    },
    "factors": [
        {
            "name": "ph_level",
            "levels": ["6", "9"],
            "type": "continuous",
            "unit": "pH",
            "description": "Treatment pH level"
        },
        {
            "name": "retention_time",
            "levels": ["4", "12"],
            "type": "continuous",
            "unit": "hours",
            "description": "Hydraulic retention time"
        },
        {
            "name": "aeration_rate",
            "levels": ["2", "6"],
            "type": "continuous",
            "unit": "L/min",
            "description": "Aeration rate"
        },
        {
            "name": "flocculant_dose",
            "levels": ["10", "50"],
            "type": "continuous",
            "unit": "mg/L",
            "description": "Flocculant dosage"
        },
        {
            "name": "temperature",
            "levels": ["15", "30"],
            "type": "continuous",
            "unit": "C",
            "description": "Wastewater temperature"
        },
        {
            "name": "mixing_intensity",
            "levels": ["low", "high"],
            "type": "ordinal",
            "unit": "",
            "description": "Mixing intensity setting"
        },
        {
