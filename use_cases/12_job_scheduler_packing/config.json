{
    "metadata": {
        "name": "Job Scheduler Packing Optimization",
        "description": "Optimize HPC job scheduler packing parameters to maximize throughput and resource efficiency",
        "version": "1.0",
        "author": "HPC Operations Team"
    },
    "factors": [
        {
            "name": "nodes",
            "type": "continuous",
            "unit": "count",
            "levels": [
                "4",
                "64"
            ]
        },
        {
            "name": "tasks_per_node",
            "type": "continuous",
            "unit": "count",
            "levels": [
                "8",
                "48"
            ]
        },
        {
            "name": "mem_per_task",
            "type": "continuous",
            "unit": "GB",
            "levels": [
                "1",
                "8"
            ]
        }
    ],
    "fixed": {
        "partition": "compute",
        "walltime": "4h"
    },
    "responses": [
        {
            "name": "throughput",
            "objective": "maximize",
            "unit": "jobs/h"
        },
        {
            "name": "efficiency",
            "objective": "maximize",
            "unit": "%"
        }
    ],
    "design": "central_composite",
    "runner": {
        "command": "bash sim.sh",
        "timeout": 60
    },
    "settings": {
        "replicates": 1,
        "randomize": true,
        "seed": 2024,
        "test_script": "use_cases/12_job_scheduler_packing/sim.sh",
        "out_directory": "use_cases/12_job_scheduler_packing/results",
        "processed_directory": "use_cases/12_job_scheduler_packing/results/analysis",
        "block_count": 1,
        "operation": "central_composite"
    }
}