{
    "metadata": {
        "name": "Chaos Engineering Blast Radius",
        "description": "Central Composite design to optimize failure injection, experiment duration, and steady state threshold for resilience"
    },
    "factors": [
        {
            "name": "failure_injection_pct",
            "levels": [
                "5",
                "50"
            ],
            "type": "continuous",
            "unit": "%",
            "description": "Failure injection percentage"
        },
        {
            "name": "experiment_duration_min",
            "levels": [
                "5",
                "30"
            ],
            "type": "continuous",
            "unit": "min",
            "description": "Chaos experiment duration"
        },
        {
            "name": "steady_state_threshold",
            "levels": [
                "0.9",
                "0.99"
            ],
            "type": "continuous",
            "unit": "ratio",
            "description": "Steady state success threshold"
        }
    ],
    "fixed_factors": {
        "tool": "litmus",
        "target": "microservices"
    },
    "responses": [
        {
            "name": "resilience_score",
            "optimize": "maximize",
            "unit": "score",
            "description": "System resilience score",
            "weight": 1.5
        },
        {
            "name": "blast_radius_services",
            "optimize": "minimize",
            "unit": "count",
            "description": "Number of affected services",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/86_chaos_engineering_blast_radius/sim.sh",
        "operation": "central_composite",
        "processed_directory": "use_cases/86_chaos_engineering_blast_radius/results/analysis",
        "out_directory": "use_cases/86_chaos_engineering_blast_radius/results"
    }
}
