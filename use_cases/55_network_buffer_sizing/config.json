{
    "metadata": {
        "name": "Network Buffer Sizing",
        "description": "Latin Hypercube of 4 kernel network buffer parameters for throughput and latency"
    },
    "factors": [
        {
            "name": "netdev_budget",
            "levels": [
                "128",
                "1024"
            ],
            "type": "continuous",
            "unit": "packets",
            "description": "NAPI polling budget"
        },
        {
            "name": "txqueuelen",
            "levels": [
                "500",
                "10000"
            ],
            "type": "continuous",
            "unit": "packets",
            "description": "Transmit queue length"
        },
        {
            "name": "tcp_wmem_max_kb",
            "levels": [
                "256",
                "16384"
            ],
            "type": "continuous",
            "unit": "KB",
            "description": "Max TCP write buffer"
        },
        {
            "name": "backlog_max",
            "levels": [
                "1000",
                "65536"
            ],
            "type": "continuous",
            "unit": "packets",
            "description": "Netdev backlog max"
        }
    ],
    "fixed_factors": {
        "nic": "mlx5",
        "ring_buffer": "4096"
    },
    "responses": [
        {
            "name": "throughput_gbps",
            "optimize": "maximize",
            "unit": "Gbps",
            "description": "Network throughput",
            "weight": 1.5
        },
        {
            "name": "softirq_pct",
            "optimize": "minimize",
            "unit": "%",
            "description": "CPU time in softirq",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/55_network_buffer_sizing/sim.sh",
        "operation": "latin_hypercube",
        "processed_directory": "use_cases/55_network_buffer_sizing/results/analysis",
        "out_directory": "use_cases/55_network_buffer_sizing/results"
    }
}
