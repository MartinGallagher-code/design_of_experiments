{
    "metadata": {
        "name": "MPI Collective Tuning",
        "description": "Plackett-Burman screening design to optimize MPI collective communication performance across 6 factors"
    },
    "factors": [
        {
            "name": "msg_size",
            "levels": [
                "4096",
                "1048576"
            ],
            "type": "continuous",
            "unit": "bytes",
            "description": "Message size for collective operations"
        },
        {
            "name": "algorithm",
            "levels": [
                "ring",
                "recursive_doubling"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Allreduce algorithm variant"
        },
        {
            "name": "ppn",
            "levels": [
                "16",
                "64"
            ],
            "type": "continuous",
            "unit": "",
            "description": "Processes per node"
        },
        {
            "name": "eager_limit",
            "levels": [
                "4096",
                "262144"
            ],
            "type": "continuous",
            "unit": "bytes",
            "description": "Eager/rendezvous protocol threshold"
        },
        {
            "name": "binding",
            "levels": [
                "core",
                "socket"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Process binding policy"
        },
        {
            "name": "coll_tuning",
            "levels": [
                "on",
                "off"
            ],
            "type": "categorical",
            "unit": "",
            "description": "MPI collective auto-tuning"
        }
    ],
    "fixed_factors": {
        "nodes": "32",
        "mpi_impl": "openmpi"
    },
    "responses": [
        {
            "name": "allreduce_latency",
            "optimize": "minimize",
            "unit": "us",
            "description": "Allreduce latency"
        },
        {
            "name": "bandwidth",
            "optimize": "maximize",
            "unit": "GB/s",
            "description": "Effective bandwidth"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 2,
        "test_script": "use_cases/07_mpi_collective_tuning/sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "use_cases/07_mpi_collective_tuning/results/analysis",
        "out_directory": "use_cases/07_mpi_collective_tuning/results"
    }
}