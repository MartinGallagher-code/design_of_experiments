{
    "metadata": {
        "name": "Sleep Quality Optimization",
        "description": "Central composite design to maximize sleep quality score and minimize wake-ups by tuning room temperature, screen cutoff time, and caffeine cutoff hour"
    },
    "factors": [
        {
            "name": "room_temp",
            "levels": [
                "16",
                "22"
            ],
            "type": "continuous",
            "unit": "C",
            "description": "Bedroom temperature"
        },
        {
            "name": "screen_cutoff",
            "levels": [
                "30",
                "120"
            ],
            "type": "continuous",
            "unit": "min",
            "description": "Minutes before bed screens are turned off"
        },
        {
            "name": "caffeine_cutoff",
            "levels": [
                "6",
                "14"
            ],
            "type": "continuous",
            "unit": "hrs_before",
            "description": "Hours before bed to stop caffeine"
        }
    ],
    "fixed_factors": {
        "bedtime": "22:30",
        "wake_time": "06:30"
    },
    "responses": [
        {
            "name": "sleep_score",
            "optimize": "maximize",
            "unit": "pts",
            "description": "Sleep quality score (1-100)",
            "weight": 1.5
        },
        {
            "name": "wake_count",
            "optimize": "minimize",
            "unit": "count",
            "description": "Number of nighttime wake-ups",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/107_sleep_quality/sim.sh",
        "operation": "central_composite",
        "processed_directory": "use_cases/107_sleep_quality/results/analysis",
        "out_directory": "use_cases/107_sleep_quality/results"
    }
}
