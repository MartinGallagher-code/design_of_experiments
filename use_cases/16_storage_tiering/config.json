{
    "metadata": {
        "name": "Burst Buffer / Storage Tiering Optimization",
        "description": "Optimize storage tiering and burst buffer configuration for HPC I/O workloads on GPFS",
        "version": "1.0",
        "author": "HPC Storage Team"
    },
    "factors": [
        {
            "name": "burst_buffer",
            "type": "categorical",
            "levels": [
                "off",
                "on"
            ]
        },
        {
            "name": "stage_in",
            "type": "categorical",
            "levels": [
                "sync",
                "async"
            ]
        },
        {
            "name": "cache_size",
            "type": "continuous",
            "unit": "GB",
            "levels": [
                "64",
                "512"
            ]
        },
        {
            "name": "write_policy",
            "type": "categorical",
            "levels": [
                "write_back",
                "write_through"
            ]
        },
        {
            "name": "prefetch",
            "type": "categorical",
            "levels": [
                "off",
                "on"
            ]
        }
    ],
    "fixed": {
        "pfs": "gpfs",
        "job_count": 100
    },
    "responses": [
        {
            "name": "io_throughput",
            "objective": "maximize",
            "unit": "GB/s",
            "weight": 1.5
        },
        {
            "name": "stage_time",
            "objective": "minimize",
            "unit": "sec",
            "weight": 1.0
        }
    ],
    "design": "fractional_factorial",
    "runner": {
        "command": "bash sim.sh",
        "timeout": 60
    },
    "settings": {
        "replicates": 1,
        "randomize": true,
        "seed": 2024,
        "test_script": "use_cases/16_storage_tiering/sim.sh",
        "out_directory": "use_cases/16_storage_tiering/results",
        "processed_directory": "use_cases/16_storage_tiering/results/analysis",
        "block_count": 1,
        "operation": "fractional_factorial"
    }
}
