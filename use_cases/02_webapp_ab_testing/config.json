{
    "metadata": {
        "name": "Web App A/B Testing",
        "description": "Full factorial design to optimize conversion rate across UI variants"
    },
    "factors": [
        {"name": "font_size",    "levels": ["small", "medium", "large"], "type": "categorical", "description": "Body text font size"},
        {"name": "color_scheme", "levels": ["dark", "light"],            "type": "categorical", "description": "UI color theme"},
        {"name": "layout",       "levels": ["grid", "list"],             "type": "categorical", "description": "Product listing layout"}
    ],
    "fixed_factors": {
        "page": "homepage",
        "traffic_pct": "10"
    },
    "responses": [
        {"name": "conversion_rate", "optimize": "maximize", "unit": "%", "description": "Visitor-to-purchase conversion rate"}
    ],
    "runner": {
        "arg_style": "env"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/02_webapp_ab_testing/sim.sh",
        "operation": "full_factorial",
        "processed_directory": "use_cases/02_webapp_ab_testing/results/analysis",
        "out_directory": "use_cases/02_webapp_ab_testing/results"
    }
}
