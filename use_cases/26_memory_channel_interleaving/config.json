{
    "metadata": {
        "name": "Memory Channel & Rank Interleaving",
        "description": "Full factorial design to optimize memory interleaving and sub-NUMA clustering for bandwidth-sensitive HPC workloads"
    },
    "factors": [
        {
            "name": "snc_mode",
            "levels": ["disabled", "snc4"],
            "type": "categorical",
            "unit": "",
            "description": "Sub-NUMA Clustering mode (disabled or 4 clusters per socket)"
        },
        {
            "name": "channel_interleave",
            "levels": ["1way", "8way"],
            "type": "categorical",
            "unit": "",
            "description": "Memory channel interleaving granularity"
        },
        {
            "name": "rank_interleave",
            "levels": ["1way", "4way"],
            "type": "categorical",
            "unit": "",
            "description": "Memory rank interleaving"
        },
        {
            "name": "dimms_per_channel",
            "levels": ["1", "2"],
            "type": "continuous",
            "unit": "",
            "description": "DIMMs populated per memory channel"
        }
    ],
    "fixed_factors": {
        "sockets": "2",
        "channels_per_socket": "8",
        "dimm_type": "DDR5_4800",
        "processor": "Xeon_8490H"
    },
    "responses": [
        {
            "name": "stream_triad_GBs",
            "optimize": "maximize",
            "unit": "GB/s",
            "description": "STREAM Triad bandwidth"
        },
        {
            "name": "random_lat_ns",
            "optimize": "minimize",
            "unit": "ns",
            "description": "Random-access memory latency"
        }
    ],
    "runner": { "arg_style": "double-dash" },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/26_memory_channel_interleaving/sim.sh",
        "operation": "full_factorial",
        "processed_directory": "use_cases/26_memory_channel_interleaving/results/analysis",
        "out_directory": "use_cases/26_memory_channel_interleaving/results"
    }
}
