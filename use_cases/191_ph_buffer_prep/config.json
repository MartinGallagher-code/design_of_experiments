        },
        {
            "name": "temp_sensitivity",
            "optimize": "minimize",
            "unit": "dpH/dC",
            "description": "pH change per degree Celsius",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/191_ph_buffer_prep/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/191_ph_buffer_prep/results/analysis",
        "out_directory": "use_cases/191_ph_buffer_prep/results"
    }
