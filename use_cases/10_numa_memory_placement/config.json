{
    "metadata": {
        "name": "NUMA Memory Placement",
        "description": "Full factorial design to optimize memory placement and thread binding on a dual-socket NUMA system"
    },
    "factors": [
        {
            "name": "mem_policy",
            "levels": [
                "local",
                "interleave"
            ],
            "type": "categorical",
            "unit": "",
            "description": "NUMA memory allocation policy"
        },
        {
            "name": "thread_bind",
            "levels": [
                "close",
                "spread"
            ],
            "type": "categorical",
            "unit": "",
            "description": "OpenMP thread binding strategy"
        },
        {
            "name": "hugepages",
            "levels": [
                "off",
                "2M"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Huge page configuration"
        }
    ],
    "fixed_factors": {
        "sockets": "2",
        "cores_per_socket": "32"
    },
    "responses": [
        {
            "name": "stream_triad",
            "optimize": "maximize",
            "unit": "GB/s",
            "description": "STREAM Triad memory bandwidth",
            "weight": 1.5
        },
        {
            "name": "latency_ns",
            "optimize": "minimize",
            "unit": "ns",
            "description": "Average memory access latency",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/10_numa_memory_placement/sim.sh",
        "operation": "full_factorial",
        "processed_directory": "use_cases/10_numa_memory_placement/results/analysis",
        "out_directory": "use_cases/10_numa_memory_placement/results"
    }
}
