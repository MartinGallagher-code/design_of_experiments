{
    "metadata": {
        "name": "Wave Energy Converter Tuning",
        "description": "Box-Behnken design to maximize power capture and minimize mechanical stress by tuning buoy diameter, draft depth, and PTO damping"
    },
    "factors": [
        {
            "name": "buoy_diam_m",
            "levels": [
                "3",
                "8"
            ],
            "type": "continuous",
            "unit": "m",
            "description": "Buoy diameter"
        },
        {
            "name": "draft_m",
            "levels": [
                "2",
                "6"
            ],
            "type": "continuous",
            "unit": "m",
            "description": "Draft depth below waterline"
        },
        {
            "name": "pto_damping",
            "levels": [
                "1000",
                "5000"
            ],
            "type": "continuous",
            "unit": "Ns/m",
            "description": "Power take-off damping coefficient"
        }
    ],
    "fixed_factors": {
        "wave_height": "1.5m",
        "wave_period": "8s"
    },
    "responses": [
        {
            "name": "power_kw",
            "optimize": "maximize",
            "unit": "kW",
            "description": "Average power output",
            "weight": 1.5
        },
        {
            "name": "stress_mpa",
            "optimize": "minimize",
            "unit": "MPa",
            "description": "Peak mooring stress",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/255_wave_energy_buoy/sim.sh",
        "operation": "box_behnken",
        "processed_directory": "use_cases/255_wave_energy_buoy/results/analysis",
        "out_directory": "use_cases/255_wave_energy_buoy/results"
    }
}
