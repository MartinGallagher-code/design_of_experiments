{
    "metadata": {
        "name": "Power Capping & Performance Trade-off",
        "description": "Central composite design to map the power-performance Pareto frontier on GPU-accelerated HPC nodes"
    },
    "factors": [
        {
            "name": "cpu_power_cap",
            "levels": [
                "120",
                "240"
            ],
            "type": "continuous",
            "unit": "watts",
            "description": "CPU package power limit (RAPL)"
        },
        {
            "name": "gpu_power_cap",
            "levels": [
                "200",
                "400"
            ],
            "type": "continuous",
            "unit": "watts",
            "description": "GPU board power limit"
        },
        {
            "name": "mem_freq",
            "levels": [
                "2400",
                "3200"
            ],
            "type": "continuous",
            "unit": "MHz",
            "description": "Memory frequency setting"
        }
    ],
    "fixed_factors": {
        "cpu_model": "EPYC_9654",
        "gpu_model": "H100_SXM",
        "nodes": "4",
        "workload": "HPL"
    },
    "responses": [
        {
            "name": "gflops",
            "optimize": "maximize",
            "unit": "GFLOPS",
            "description": "Sustained double-precision GFLOPS",
            "weight": 1.5
        },
        {
            "name": "gflops_per_watt",
            "optimize": "maximize",
            "unit": "GFLOPS/W",
            "description": "Energy efficiency metric",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "use_cases/20_power_performance_tradeoff/sim.sh",
        "operation": "central_composite",
        "processed_directory": "use_cases/20_power_performance_tradeoff/results/analysis",
        "out_directory": "use_cases/20_power_performance_tradeoff/results"
    }
}
