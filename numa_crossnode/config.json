{
    "metadata": {
        "name": "NUMA Cross-Node Memory Benchmark",
        "description": "Measure bandwidth and latency when a specific CPU accesses memory on a given NUMA node"
    },
    "factors": [
        {
            "name": "cpu_id",
            "levels": ["0", "3"],
            "type": "ordinal",
            "dtype": "int",
            "description": "Logical CPU to pin to (adjust range to match your system)"
        },
        {
            "name": "mem_node",
            "levels": ["0", "1"],
            "type": "categorical",
            "description": "NUMA node where memory is allocated"
        },
        {
            "name": "buffer_size",
            "levels": ["4096", "65536", "1048576", "16777216", "67108864", "268435456", "1073741824"],
            "type": "ordinal",
            "unit": "bytes",
            "dtype": "int",
            "description": "Working-set size: 4K, 64K, 1M, 16M, 64M, 256M, 1G (log-spaced)"
        },
        {
            "name": "mode",
            "levels": ["bandwidth_read", "bandwidth_write", "latency"],
            "type": "categorical",
            "description": "Measurement type: sequential read, sequential write, or pointer-chase latency"
        }
    ],
    "responses": [
        {
            "name": "bandwidth_mib_s",
            "optimize": "maximize",
            "unit": "MiB/s",
            "description": "Memory bandwidth (sequential access modes only)"
        },
        {
            "name": "latency_ns",
            "optimize": "minimize",
            "unit": "ns",
            "description": "Per-access latency (pointer-chase mode only)"
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "operation": "linear_sweep",
        "block_count": 1,
        "test_script": "./numa_crossnode/bench.sh",
        "out_directory": "./numa_crossnode/results",
        "processed_directory": "./numa_crossnode/results/analysis"
    }
}
