{
    "metadata": {
        "name": "sysbench memory benchmark",
        "description": "Identify which factors most affect memory throughput and latency"
    },
    "factors": [
        {"name": "threads",           "levels": ["1", "4"],             "type": "continuous",  "description": "Worker thread count"},
        {"name": "memory_block_size", "levels": ["1K", "16K"],          "type": "categorical", "description": "Memory block size"},
        {"name": "memory_scope_type", "levels": ["global", "local"],    "type": "categorical"},
        {"name": "memory_access_mode","levels": ["seq", "rnd"],         "type": "categorical"},
        {"name": "memory_oper",       "levels": ["read", "write"],      "type": "categorical"},
        {"name": "rand_type",         "levels": ["special", "uniform"], "type": "categorical"}
    ],
    "fixed_factors": {
        "time": "10",
        "warmup-time": "3"
    },
    "responses": [
        {"name": "response",      "optimize": "maximize", "unit": "MiB/sec", "description": "Memory throughput"},
        {"name": "p95_latency_ms","optimize": "minimize", "unit": "ms",      "description": "95th percentile latency"}
    ],
    "settings": {
        "block_count": 2,
        "test_script": "examples/sysbench_test.sh",
        "operation": "plackett_burman",
        "processed_directory": "results/sysbench/analysis",
        "out_directory": "results/sysbench"
    }
}
