{
    "metadata": {
        "name": "Compiler Optimization Flags Screening",
        "description": "Screen GCC 13 compiler flags to minimize execution time and binary size for NPB BT benchmark",
        "version": "1.0",
        "author": "HPC Compiler Team"
    },
    "factors": [
        {
            "name": "opt_level",
            "type": "categorical",
            "levels": [
                "O2",
                "O3"
            ]
        },
        {
            "name": "vectorize",
            "type": "categorical",
            "levels": [
                "off",
                "avx512"
            ]
        },
        {
            "name": "lto",
            "type": "categorical",
            "levels": [
                "off",
                "on"
            ]
        },
        {
            "name": "march",
            "type": "categorical",
            "levels": [
                "native",
                "znver3"
            ]
        },
        {
            "name": "unroll",
            "type": "categorical",
            "levels": [
                "off",
                "on"
            ]
        },
        {
            "name": "fast_math",
            "type": "categorical",
            "levels": [
                "off",
                "on"
            ]
        },
        {
            "name": "pgo",
            "type": "categorical",
            "levels": [
                "off",
                "on"
            ]
        }
    ],
    "fixed": {
        "compiler": "gcc13",
        "benchmark": "npb_bt"
    },
    "responses": [
        {
            "name": "exec_time",
            "objective": "minimize",
            "unit": "sec",
            "weight": 1.5
        },
        {
            "name": "binary_size",
            "objective": "minimize",
            "unit": "MB",
            "weight": 1.0
        }
    ],
    "design": "plackett_burman",
    "block_count": 1,
    "runner": {
        "command": "bash sim.sh",
        "timeout": 60
    },
    "settings": {
        "replicates": 1,
        "randomize": true,
        "seed": 2024,
        "test_script": "./sim.sh",
        "out_directory": "./results",
        "processed_directory": "./results/analysis",
        "block_count": 1,
        "operation": "plackett_burman"
    }
}
