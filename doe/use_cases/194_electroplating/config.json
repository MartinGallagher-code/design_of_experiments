        },
        {
            "name": "adhesion_score",
            "optimize": "maximize",
            "unit": "pts",
            "description": "Adhesion tape test score (1-5)",
            "weight": 1.5
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "./sim.sh",
        "operation": "plackett_burman",
        "processed_directory": "./results/analysis",
        "out_directory": "./results"
    }
}
