{
    "metadata": {
        "name": "Electroplating Thickness Control",
        "description": "Plackett-Burman screening of current density, bath temperature, plating time, pH, and agitation for uniform coating thickness and adhesion"
    },
    "factors": [
        {
            "name": "current_density",
            "levels": [
                "1",
                "10"
            ],
            "type": "continuous",
            "unit": "A/dm2",
            "description": "Cathode current density"
        },
        {
            "name": "bath_temp_c",
            "levels": [
                "20",
                "55"
            ],
            "type": "continuous",
            "unit": "C",
            "description": "Plating bath temperature"
        },
        {
            "name": "time_min",
            "levels": [
                "5",
                "60"
            ],
            "type": "continuous",
            "unit": "min",
            "description": "Plating duration"
        },
        {
            "name": "bath_ph",
            "levels": [
                "2",
                "5"
            ],
            "type": "continuous",
            "unit": "pH",
            "description": "Bath pH"
        },
        {
            "name": "agitation_rpm",
            "levels": [
                "0",
                "200"
            ],
            "type": "continuous",
            "unit": "rpm",
            "description": "Bath agitation speed"
        }
    ],
    "fixed_factors": {
        "metal": "nickel",
        "substrate": "mild_steel"
    },
    "responses": [
        {
            "name": "thickness_um",
            "optimize": "maximize",
            "unit": "um",
            "description": "Average coating thickness",
