{
    "metadata": {
        "name": "GPU Kernel Optimization",
        "description": "Full factorial design to optimize GPU kernel launch parameters for maximum throughput and occupancy"
    },
    "factors": [
        {
            "name": "block_size",
            "levels": [
                "128",
                "512"
            ],
            "type": "continuous",
            "unit": "threads",
            "description": "CUDA block size"
        },
        {
            "name": "shared_mem",
            "levels": [
                "16",
                "48"
            ],
            "type": "continuous",
            "unit": "KB",
            "description": "Shared memory per block"
        },
        {
            "name": "unroll_factor",
            "levels": [
                "2",
                "8"
            ],
            "type": "continuous",
            "unit": "",
            "description": "Loop unroll factor"
        },
        {
            "name": "precision",
            "levels": [
                "fp32",
                "fp64"
            ],
            "type": "categorical",
            "unit": "",
            "description": "Floating-point precision"
        }
    ],
    "fixed_factors": {
        "gpu_model": "A100",
        "problem_size": "8192"
    },
    "responses": [
        {
            "name": "gflops",
            "optimize": "maximize",
            "unit": "GFLOPS",
            "description": "Achieved floating-point throughput",
            "weight": 1.5
        },
        {
            "name": "occupancy",
            "optimize": "maximize",
            "unit": "%",
            "description": "SM occupancy percentage",
            "weight": 1.5
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "./sim.sh",
        "operation": "full_factorial",
        "processed_directory": "./results/analysis",
        "out_directory": "./results"
    }
}
