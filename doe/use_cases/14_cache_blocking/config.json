{
    "metadata": {
        "name": "Cache Blocking Strategy Optimization",
        "description": "Optimize cache blocking tile sizes and prefetch distance for DGEMM on a 4096x4096 matrix",
        "version": "1.0",
        "author": "HPC Performance Engineering"
    },
    "factors": [
        {
            "name": "block_i",
            "type": "continuous",
            "unit": "elements",
            "levels": [
                "16",
                "256"
            ]
        },
        {
            "name": "block_j",
            "type": "continuous",
            "unit": "elements",
            "levels": [
                "16",
                "256"
            ]
        },
        {
            "name": "block_k",
            "type": "continuous",
            "unit": "elements",
            "levels": [
                "16",
                "256"
            ]
        },
        {
            "name": "prefetch_dist",
            "type": "continuous",
            "unit": "iterations",
            "levels": [
                "1",
                "8"
            ]
        }
    ],
    "fixed": {
        "matrix_size": 4096,
        "algorithm": "dgemm"
    },
    "responses": [
        {
            "name": "gflops",
            "objective": "maximize",
            "unit": "GFLOPS",
            "weight": 1.5
        },
        {
            "name": "cache_miss_rate",
            "objective": "minimize",
            "unit": "%",
            "weight": 1.0
        }
    ],
    "design": "latin_hypercube",
    "lhs_samples": 25,
    "runner": {
        "command": "bash sim.sh",
        "timeout": 60
    },
    "settings": {
        "replicates": 1,
        "randomize": true,
        "seed": 2024,
        "test_script": "./sim.sh",
        "out_directory": "./results",
        "processed_directory": "./results/analysis",
        "block_count": 1,
        "operation": "latin_hypercube",
        "lhs_samples": 25
    }
}
