        },
        {
            "name": "fatigue_score",
            "optimize": "minimize",
            "unit": "pts",
            "description": "Accumulated fatigue score (1-10)",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "./sim.sh",
        "operation": "full_factorial",
        "processed_directory": "./results/analysis",
        "out_directory": "./results"
    }
