{
    "metadata": {
        "name": "Feature Store Freshness",
        "description": "Latin Hypercube of 4 feature store parameters for serving latency and feature freshness"
    },
    "factors": [
        {
            "name": "materialization_interval_m",
            "levels": [
                "1",
                "60"
            ],
            "type": "continuous",
            "unit": "min",
            "description": "Feature materialization interval"
        },
        {
            "name": "cache_ttl_s",
            "levels": [
                "10",
                "300"
            ],
            "type": "continuous",
            "unit": "s",
            "description": "Online store cache TTL"
        },
        {
            "name": "batch_size",
            "levels": [
                "100",
                "10000"
            ],
            "type": "continuous",
            "unit": "rows",
            "description": "Materialization batch size"
        },
        {
            "name": "online_replicas",
            "levels": [
                "1",
                "6"
            ],
            "type": "continuous",
            "unit": "count",
            "description": "Online store replica count"
        }
    ],
    "fixed_factors": {
        "offline_store": "s3_parquet",
        "online_store": "redis"
    },
    "responses": [
        {
            "name": "serving_latency_ms",
            "optimize": "minimize",
            "unit": "ms",
            "description": "Feature serving p99 latency",
            "weight": 1.0
        },
        {
            "name": "freshness_lag_min",
            "optimize": "minimize",
            "unit": "min",
            "description": "Feature freshness lag",
            "weight": 1.5
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "./sim.sh",
        "operation": "latin_hypercube",
        "processed_directory": "./results/analysis",
        "out_directory": "./results"
    }
}
