{
    "metadata": {
        "name": "LED Strip Installation",
        "description": "Box-Behnken design to maximize brightness uniformity and minimize hot spots by tuning strip density, power supply headroom, and diffuser distance"
    },
    "factors": [
        {
            "name": "leds_per_m",
            "levels": [
                "30",
                "120"
            ],
            "type": "continuous",
            "unit": "LEDs/m",
            "description": "LED density per meter"
        },
        {
            "name": "psu_headroom_pct",
            "levels": [
                "10",
                "40"
            ],
            "type": "continuous",
            "unit": "%",
            "description": "Power supply overhead above rated load"
        },
        {
            "name": "diffuser_mm",
            "levels": [
                "5",
                "30"
            ],
            "type": "continuous",
            "unit": "mm",
            "description": "Diffuser distance from LEDs"
        }
    ],
    "fixed_factors": {
        "voltage": "12V",
        "color": "warm_white"
    },
    "responses": [
        {
            "name": "uniformity_pct",
            "optimize": "maximize",
            "unit": "%",
            "description": "Brightness uniformity across length",
            "weight": 1.5
        },
        {
            "name": "hotspot_temp_c",
            "optimize": "minimize",
            "unit": "C",
            "description": "Maximum LED junction temperature rise",
            "weight": 1.0
        }
    ],
    "runner": {
        "arg_style": "double-dash"
    },
    "settings": {
        "block_count": 1,
        "test_script": "./sim.sh",
        "operation": "box_behnken",
        "processed_directory": "./results/analysis",
        "out_directory": "./results"
    }
}
